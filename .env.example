# Django安全密钥（生产环境请替换为随机生成的密钥）
SECRET_KEY=your-secret-key-here

# 调试模式（生产环境务必设为False）
DEBUG=False

# 允许访问的主机名，逗号分隔
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF信任来源，逗号分隔
CSRF_TRUSTED_ORIGINS=https://gun.obara.com.cn

# HTTPS安全配置
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# 数据库配置（默认使用SQLite，如需MySQL请修改以下配置）
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_CHARSET=utf8mb4

# Coze AI配置
COZE_BOT_ID=
COZE_USER_ID=
COZE_API_TOKEN=

# 腾讯元器AI配置
YUANQI_ASSISTANT_ID=
YUANQI_API_KEY=
YUANQI_USER_ID=

# Gitee配置
GITEE_TOKEN=
